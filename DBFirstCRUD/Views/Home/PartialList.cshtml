@model IEnumerable<DBFirstCRUD.Models.Employee>

<table class="table table-stripped">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>DOB</th>
        <th>Age</th>
    </tr>

    @foreach(var item in Model) 
    { 
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.DOB</td>
            <td>@item.Age</td>
        </tr>    
    }
</table>